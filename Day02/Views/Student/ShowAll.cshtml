@model List<Student>

<div class="container mt-4">
    <h2 class="mb-4">All Students</h2>
    <table class="table table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Age</th>
                <th>Department</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Age</td>
                    <td>@(item.Department?.Name ?? "N/A")</td>
                    <td>
                        <a asp-action="ShowDetails" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                            View Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>