@model Student

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Student Profile: @Model.Name</h3>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3 font-weight-bold">Student ID:</div>
                <div class="col-md-9">@Model.Id</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 font-weight-bold">Age:</div>
                <div class="col-md-9">@Model.Age</div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3 font-weight-bold">Department:</div>
                <div class="col-md-9">@(Model.Department?.Name ?? "No Department Assigned")</div>
            </div>

            <hr />
            <h4>Academic Record</h4>
            @if (Model.StuCrsRes.Any())
            {
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Grade</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var res in Model.StuCrsRes)
                        {
                            <tr>
                                <td>@res.Course.Name</td>
                                <td><span class="badge badge-info text-dark">@res.Grade</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted italic">No courses enrolled yet.</p>
            }
        </div>
        <div class="card-footer">
            <a asp-action="ShowAll" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>