@model Department
@{
    ViewData["Title"] = "New Department";
}

<h1>New Department</h1>

<form method="post" asp-action="SaveAdd">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="ManagerName" class="control-label"></label>
        <input asp-for="ManagerName" class="form-control" />
        <span asp-validation-for="ManagerName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Create" class="btn btn-primary mt-3 mb-3" />
    </div>
</form>
<a href="/Department/Index">Back To List</a>
